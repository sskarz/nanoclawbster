
# =============================================================================
# NanoClawbster Configuration
# =============================================================================
# Run `bash setup.sh` to fill these in interactively.

# --- Authentication (one of these is required) ---
ANTHROPIC_API_KEY=                           # Anthropic API key (pay-per-use)
# CLAUDE_CODE_OAUTH_TOKEN=                   # Or: Claude subscription token (run `claude setup-token`)

# --- Discord (required) ---
DISCORD_BOT_TOKEN=                           # From https://discord.com/developers/applications
ASSISTANT_NAME=Andy                          # The @mention trigger word (default: Andy)

# --- Composio (optional — for 1000+ app integrations like Gmail, GitHub) ---
COMPOSIO_API_KEY=                            # API key from https://app.composio.dev/settings
WEBHOOK_PORT=3456                            # Port for incoming webhook server
COMPOSIO_WEBHOOK_SECRET=                     # Webhook signing secret from Composio Project Settings
COMPOSIO_WEBHOOK_URL=                        # Public URL for webhook delivery (e.g. https://yourdomain.com/webhook/composio)

# --- RetellAI (optional — for outbound phone calls) ---
# RETELL_API_KEY=                             # API key from https://www.retellai.com
# RETELL_WEBHOOK_GROUP=                       # Group folder to receive call analysis results

# --- Fitbit OAuth (optional — enables /fitbit/callback route for token exchange) ---
# FITBIT_CLIENT_ID=                           # Client ID from https://dev.fitbit.com
# FITBIT_CLIENT_SECRET=                       # Client Secret from https://dev.fitbit.com
# FITBIT_REDIRECT_URI=https://yourdomain.com/fitbit/callback  # Must match Fitbit app settings
# FITBIT_TOKEN_PATH=/path/to/.fitbit-token.json               # Where to save the OAuth token

# --- Container Tuning (optional) ---
CONTAINER_IMAGE=nanoclawbster-agent:latest   # Docker image name for agent containers
CONTAINER_TIMEOUT=1800000                    # Container timeout in ms (default: 30 min)
IDLE_TIMEOUT=1800000                         # Idle timeout before closing container stdin (default: 30 min)
MAX_CONCURRENT_CONTAINERS=5                  # Max parallel agent containers
# CONTAINER_MAX_OUTPUT_SIZE=10485760         # Max container output in bytes (default: 10 MB)
# MAX_SESSION_FILE_SIZE=10485760             # Max session file size in bytes (default: 10 MB)

# --- General (optional) ---
# TZ=America/Los_Angeles                     # Timezone for scheduled tasks (default: America/Los_Angeles)
# LOG_LEVEL=info                             # Logging verbosity: trace, debug, info, warn, error
